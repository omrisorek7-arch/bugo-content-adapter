ANTHROPIC_API_KEY=your_key_here
GOOGLE_DOC_ID=your_google_doc_id_here
GOOGLE_DRIVE_VIDEO_FOLDER_ID=your_video_folder_id_here

# =============================================================================
# Profile picker — appears in all 4 tabs (Indoor / Outdoor / Replicator / Pets).
# Each profile = one (Google Doc + Google Drive folder + display label) triple.
# Ido and Hadar are always visible. Profile 3 and Profile 4 appear only when
# BOTH the Doc and Folder IDs are filled in.
#
# Each "*_ID" field accepts either a full Google URL or a bare ID:
#   Full URL:  https://docs.google.com/document/d/1abcXYZ.../edit
#   Or just:   1abcXYZ...
# =============================================================================

IDO_GOOGLE_DOC_ID=
IDO_GOOGLE_DRIVE_VIDEO_FOLDER_ID=
HADAR_GOOGLE_DOC_ID=
HADAR_GOOGLE_DRIVE_VIDEO_FOLDER_ID=

PROFILE3_GOOGLE_DOC_ID=
PROFILE3_GOOGLE_DRIVE_VIDEO_FOLDER_ID=
PROFILE3_LABEL_HE=

PROFILE4_GOOGLE_DOC_ID=
PROFILE4_GOOGLE_DRIVE_VIDEO_FOLDER_ID=
PROFILE4_LABEL_HE=
